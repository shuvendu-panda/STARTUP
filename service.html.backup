<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="service.css" />
    <link rel="stylesheet" href="navbar.css" />
    <link rel="stylesheet" href="footer.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
</head>
<body>
  <div id="header"></div>
    <section class="about-section">
    <div class="about-container">

      
        <div class="about-text">
            <h2>About Us</h2>
            <p>
                At <span class="highlight">Innovative Dev</span>, we believe every tech journey is unique.
                Whether you’re a startup preparing for investment, a business seeking efficient technological solutions,
                or a multinational enterprise in pursuit of fresh answers to persistent challenges, we are here to help.
            </p>

            <p>
                Our mission is to envision, design, and deliver the perfect solutions to meet your software development
                needs. From ideation to execution, we combine innovation, expertise, and a deep understanding of
                technology to create software that aligns with your goals and drives success.
            </p>
        </div>

      
        <div class="about-image">
            <img src="team.webp" alt="About Us Image">
        </div>

    </div>

   
    <div class="why-choose-box">
        <h3>Why Choose Us?</h3>

        <div class="choose-item">
            <span class="icon"></span>
            <div>
                <h4>Tailored Solutions</h4>
                <p>Every project is customized to fit your unique challenges.</p>
            </div>
        </div>

        <div class="choose-item">
            <span class="icon"></span>
            <div>
                <h4>Expertise Across Industries</h4>
                <p>From startups to global enterprises, we cater to diverse needs.</p>
            </div>
        </div>

        <div class="choose-item">
            <span class="icon"></span>
            <div>
                <h4>Future-Ready Designs</h4>
                <p>We build scalable, forward-thinking software that evolves with you.</p>
            </div>
        </div>
    </div>
<section class="team-section">
  <div class="team-container">
    
    <div class="team-header">
      <h2 class="team-title">Say Hello to Our Squad</h2>
      <p class="team-subtitle">
        Get ready to meet the faces behind the magic — the dreamers, the doers, and the people who make it happen.
      </p>
    </div>
     
   

    <div class="team-grid">

    
      <article class="team-card">
        <div class="image-wrap">
          <img src="s1.webp" alt="Prasang Solanki">
          <div class="image-overlay">
            <div class="overlay-title">MARKETING GENIUS</div>
            <div class="overlay-tag">Engaging</div>
          </div>
        </div>
        <div class="info">
          <h3 class="name">Himanshu</h3>
          <p class="role">Graphic Designer</p>
        </div>
      </article>

     
      <article class="team-card">
        <div class="image-wrap">
          <img src="team21.webp" alt="Rishav Ranjan">
          <div class="image-overlay">
            <div class="overlay-title">DEVELOPER &amp; DESIGNER</div>
            <div class="overlay-tag">Graphic</div>
          </div>
        </div>
        <div class="info">
          <h3 class="name">Er. suvendu</h3>
          <p class="role">Communication Manager &amp; developer</p>
        </div>
      </article>

   
      <article class="team-card">
        <div class="image-wrap">
          <img src="s2.webp" alt="Harshit Singh">
          <div class="image-overlay">
            <div class="overlay-title">DEVELOPER</div>
            <div class="overlay-tag">Visionary</div>
          </div>
        </div>
        <div class="info">
          <h3 class="name">Er. kailash</h3>
          <p class="role">Co-Founder &amp; developer</p>
        </div>
      </article>

    </div>
  </div>
</section>

</section>
<div id="footer"></div>

<script>
  fetch('navbar.html')
    .then(response => response.text())
    .then(data => document.getElementById('header').innerHTML = data);
  fetch('footer.html')
        .then(response => response.text())
        .then(data => document.getElementById('footer').innerHTML = data);
</script>





</body>
</html>